#!/usr/bin/env bash

if [ $# == 1 ]; then
	VERSION="$1"; shift
else
	echo ./make_release versao_nova >&2
	exit 1
fi

CURRENT_VERSION=($(cat version.txt | sed 's;\.; ;g'))

case "$VERSION" in
	patch)
		VERSION="${CURRENT_VERSION[0]}.${CURRENT_VERSION[1]}.$((${CURRENT_VERSION[2]}+1))"
	;;
	minor)
		VERSION="${CURRENT_VERSION[0]}.$((${CURRENT_VERSION[1]}+1)).0"
	;;
	major)
		VERSION="$((${CURRENT_VERSION[0]}+1)).0.0"
	;;
esac

# echo new version: $VERSION
# exit 0
printf "%s" "$VERSION" > version.txt

# Only stage the version bump — never git add -A (unrelated dirt, secrets, build
# artifacts would otherwise land in the release commit).
git add version.txt
git commit -sm "bump to $VERSION"
if [[ ! -v NO_TAG ]]; then
	git tag "$VERSION"
	# Push only this tag. `git push --tag` is an abbreviation of --tags and
	# would publish every local tag.
	git push origin "refs/tags/$VERSION"
fi
git push
